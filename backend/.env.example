# Copy this file to `.env` and fill in the values. NEVER commit `.env` (it holds secrets).
# `.env` is read automatically by app/core/config.py (Settings).

# Local Postgres (matches compose.yml). The app already defaults to this, so it's optional locally.
DATABASE_URL=postgresql+psycopg://dataquest:dataquest@localhost:5432/dataquest

# Your free FRED/ALFRED API key from https://fredaccount.stlouisfed.org/apikey
FRED_API_KEY=your_fred_api_key_here